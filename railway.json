{
  "build": {
    "builder": "pip",
    "watchPatterns": ["*.py", "requirements.txt"]
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/",
    "healthcheckTimeout": 100
  },
  "serviceType": "worker",
  "startCommand": "python3 kalpe_super_scanner_whatsapp.py"
}
