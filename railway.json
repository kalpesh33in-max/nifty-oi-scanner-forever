{
  "build": {
    "builder": "pip",
    "watchPatterns": [".py", "requirements.txt"]
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30
  },
  "serviceType": "worker",
  "startCommand": "python main_app.py"
}
